# 本地开发用 SQLite
DATABASE_URL="file:./dev.db"

# 线上部署用 Turso（在 Vercel 环境变量中配置）
# TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# TURSO_AUTH_TOKEN="your-auth-token"

# LLM API Keys — 配置了哪个就用哪个，多个则取中位数
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# 阿里云百炼（OpenAI 兼容接口）
BAILIAN_API_KEY=""
BAILIAN_MODEL="glm-5"

# 定时评审任务密钥
CRON_SECRET=""
